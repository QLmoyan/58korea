# Copy this file to `.env.local` and fill in your Supabase project values.
# Do NOT commit `.env.local` or real keys to Git.

NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database migrations (apply-*.ts): use one of the following
SUPABASE_DB_URL=postgresql://postgres.[project-ref]:[password]@aws-0.ap-northeast-2.pooler.supabase.com:6543/postgres
# DATABASE_URL=
# SUPABASE_DB_PASSWORD=your-database-password

# Admin bootstrap (regression-check, create-admin-user.ts)
ADMIN_BOOTSTRAP_PASSWORD=your-bootstrap-admin-password
ADMIN_PASSWORD=your-admin-password
ADMIN_SESSION_SECRET=your-admin-session-secret

# Optional: public site URL for share links and Open Graph (default http://localhost:3000)
# NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Optional: regression HTTP base (default http://localhost:3000)
# REGRESSION_BASE_URL=http://localhost:3000

# Optional: stock photo APIs for scripts/auto-post-seed.ts (Pexels → Unsplash → Pixabay)
PEXELS_API_KEY=
UNSPLASH_ACCESS_KEY=
PIXABAY_API_KEY=
